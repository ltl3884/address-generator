# Docker Compose 环境变量配置
# 用于 docker-compose.yml 文件

# MySQL 配置
MYSQL_ROOT_PASSWORD=secure_root_password_2024
MYSQL_DATABASE=address_collector_prod
MYSQL_USER=prod_user
MYSQL_PASSWORD=secure_user_password_2024

# 应用数据库连接（Docker内部网络）
DATABASE_URL=mysql://prod_user:secure_user_password_2024@mysql:3306/address_collector_prod

# 应用环境
NODE_ENV=production
LOG_LEVEL=error

# 可选：如果需要外部数据库连接
# EXTERNAL_DATABASE_URL=mysql://user:password@external-host:3306/database

# 安全配置
# 生产环境请修改这些密码为更安全的值